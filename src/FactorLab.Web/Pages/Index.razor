    private void MarkPaid(Invoice invoice)
    {
        if (!UserContext.CanOperateCollections) return;

        var collectionCase = Portfolio.CollectionCaseFor(invoice.InvoiceNumber);
        collectionCase.Status = CollectionStatus.Paid;
        collectionCase.AmountPaid = invoice.Amount;
        collectionCase.ReserveReleased = Math.Max(0m, invoice.Amount * (100m - Portfolio.Terms.AdvanceRate) / 100m);
        collectionCase.NextAction = "Reserve released and case ready to archive";
        invoice.FundingStage = FundingStage.Collected;
        Portfolio.CollectionActivities.Add(new CollectionActivity { InvoiceNumber = invoice.InvoiceNumber, ActivityType = CollectionActivityType.PaymentReceived, ContactName = invoice.Debtor, Note = "Payment matched to invoice." });
        Portfolio.CollectionActivities.Add(new CollectionActivity { InvoiceNumber = invoice.InvoiceNumber, ActivityType = CollectionActivityType.ReserveReleased, ContactName = "Operations", Note = $"Reserve released: {Money(collectionCase.ReserveReleased)}." });
        IntegrationOutbox.Publish("Collections.PaymentMatched", invoice.InvoiceNumber, $"{Money(invoice.Amount)} payment matched and reserve released.", "Power Automate");
    }

    private void Chargeback(Invoice invoice)
    {
        if (!UserContext.CanOperateCollections) return;

        var collectionCase = Portfolio.CollectionCaseFor(invoice.InvoiceNumber);
        collectionCase.Status = CollectionStatus.Chargeback;
        collectionCase.ChargebackAmount = Math.Max(0m, invoice.Amount - collectionCase.AmountPaid);
        collectionCase.NextAction = "Recover outstanding amount from client";
        Portfolio.CollectionActivities.Add(new CollectionActivity { InvoiceNumber = invoice.InvoiceNumber, ActivityType = CollectionActivityType.Chargeback, ContactName = invoice.ClientName, Note = $"Chargeback opened: {Money(collectionCase.ChargebackAmount)}." });
        IntegrationOutbox.Publish("Collections.ChargebackOpened", invoice.InvoiceNumber, $"{Money(collectionCase.ChargebackAmount)} chargeback opened for {invoice.ClientName}.", "Microsoft Teams");
    }

    private IEnumerable<string> Signals()
    {
        var decisions = Portfolio.Invoices.Select(Decide).ToArray();
        var excluded = decisions.Count(decision => !decision.IsEligible);
        yield return $"{Portfolio.Invoices.Count - excluded} invoices pass current eligibility rules.";
        if (excluded > 0) yield return $"{excluded} invoices need review before funding.";
        if (Portfolio.Invoices.Any(invoice => invoice.Status == InvoiceStatus.Disputed)) yield return "Disputed invoices are excluded from the offer.";
        if (Portfolio.Invoices.Any(invoice => invoice.ConcentrationPercent > Portfolio.Terms.RiskPolicy.ConcentrationWarningPercent)) yield return "High debtor concentration requires underwriter review.";
        if (Portfolio.Invoices.Any(invoice => invoice.DaysToPay > Portfolio.Terms.RiskPolicy.LongTenorReviewDays)) yield return "Long tenor invoices may need additional confirmation.";
        if (Portfolio.Debtors.Any(debtor => debtor.BuyDecision == BuyDecision.NoBuy)) yield return "One debtor is marked no-buy and will block funding.";
        if (Portfolio.Clients.Any(client => client.KycStatus == KycStatus.RefreshRequired)) yield return "One client needs KYC refresh before larger funding.";
    }

    private string TermSheet(FactoringSummary summary)
    {
        var rejected = Portfolio.Invoices.Where(invoice => !Decide(invoice).IsEligible).ToArray();
        var lines = new List<string>
        {
            "INDICATIVE FACTORING TERMS",
            "",
            $"Model: {(Portfolio.Terms.IsNonRecourse ? "Non-recourse" : "Recourse")}",
            $"Eligible receivables: {Money(summary.EligibleAmount)}",
            $"Advance rate: {Portfolio.Terms.AdvanceRate:0}%",
            $"Gross advance: {Money(summary.Advance)}",
            $"Estimated fees: {Money(summary.TotalCost)}",
            $"Cash today: {Money(summary.CashToday)}",
            $"Reserve at collection: {Money(summary.Reserve)}",
            $"Weighted tenor: {summary.WeightedDays:0} days",
            $"Effective APR: {summary.EffectiveApr:0.0}%",
            "",
            "UNDERWRITING CONDITIONS",
            "- Debtor confirmation before funding",
            "- No undisclosed disputes, set-offs, or credit notes",
            "- Assignment notice sent on funded invoices",
            "- Final offer subject to KYC and receivable verification",
            "",
            "DOCUMENT READINESS",
            $"- Ready invoices: {summary.DocumentReadyCount}/{Portfolio.Invoices.Count}",
            $"- Missing required documents: {summary.MissingRequiredDocuments}"
        };

        if (rejected.Length > 0)
        {
            lines.Add("");
            lines.Add("EXCLUDED INVOICES");
            foreach (var invoice in rejected)
            {
                var decision = Decide(invoice);
                lines.Add($"- {invoice.InvoiceNumber} / {invoice.Debtor} / score {decision.Score} / {string.Join("; ", decision.Blockers)}");
            }
        }

        return string.Join(Environment.NewLine, lines);
    }

