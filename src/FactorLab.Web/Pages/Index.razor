                <div class="collection-form">
                    <input placeholder="Owner" @bind="collectionCase.Owner" />
                    <input placeholder="Next action" @bind="collectionCase.NextAction" />
                </div>
                <div class="collection-actions">
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => LogCollection(invoice, CollectionActivityType.Email)">Email</button>
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => SendDebtorConfirmation(invoice)">Confirm</button>
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => LogCollection(invoice, CollectionActivityType.Call)">Call</button>
                    <button class="warning-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => SetPromiseToPay(invoice)">Promise</button>
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => MarkPaid(invoice)">Mark paid</button>
                    <button class="warning-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => OpenDispute(invoice)">Dispute</button>
                    <button class="danger-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => Chargeback(invoice)">Chargeback</button>
