@page "/"
@using FactorLab.Web.Domain
@using FactorLab.Web.Persistence
@using FactorLab.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject FactorLab.Web.Services.FactoringCalculator Calculator
@inject IPortfolioRepository Portfolio
@inject CurrentUserService UserContext
@inject IDocumentStorageService DocumentStorage
@inject IRiskMemoService RiskMemoService
@inject IDocumentExtractionService DocumentExtraction
@inject IReportExportService ReportExport
@inject IActionCenterService ActionCenter
@inject IIntegrationOutboxService IntegrationOutbox
@inject ITemplateGenerationService TemplateGeneration
@inject IPortfolioMonitoringService PortfolioMonitoring
@inject IInvoiceImportService InvoiceImport
@inject IFundingLedgerService FundingLedger
@inject IBorrowingBaseService BorrowingBase
@inject IFundingBatchService FundingBatchService
@inject IPaymentReconciliationService PaymentReconciliation
@inject IDisputeService DisputeService
@inject IDebtorConfirmationService DebtorConfirmationService
@inject IFraudSignalService FraudSignals
@inject IClientOfferService ClientOffers
@inject IJSRuntime JsRuntime

<PageTitle>FactorLab</PageTitle>

@{
    var terms = Portfolio.Terms;
    var invoices = Portfolio.Invoices;
    var summary = Calculator.Summarize(invoices, terms, Portfolio.Clients, Portfolio.Debtors);
    var actionItems = ActionCenter.BuildQueue(Portfolio, terms, CompletedActionIds);
    var myActionItems = actionItems.Where(item => UserContext.CurrentUser.Role == UserRole.Admin || item.OwnerRole == UserContext.CurrentUser.Role).ToArray();
    var covenantChecks = PortfolioMonitoring.BuildChecks(Portfolio, terms);
    var ledgerEntries = FundingLedger.BuildLedger(Portfolio, terms);
    var ledgerSummary = FundingLedger.Summarize(ledgerEntries);
    var borrowingBaseLines = BorrowingBase.Build(Portfolio, terms);
    var borrowingBaseSummary = BorrowingBase.Summarize(borrowingBaseLines);
    var fraudSignals = FraudSignals.Detect(Portfolio);
}

<section class="workspace-header">
    <div>
        <p class="eyebrow">Invoice factoring workspace</p>
        <h1>FactorLab</h1>
    </div>
    <div class="user-tools">
        <span class="@RoleBadgeClass(UserContext.CurrentUser.Role)">@UserContext.CurrentUser.Role</span>
        <select value="@UserContext.CurrentUser.Email" @onchange="SwitchUser">
            @foreach (var user in UserContext.Users)
            {
                <option value="@user.Email">@user.DisplayName</option>
            }
        </select>
        <button class="primary-action" disabled="@(!UserContext.CanSubmitFunding)" @onclick="SubmitEligible">Submit eligible</button>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span>Eligible invoices</span>
        <strong>@Money(summary.EligibleAmount)</strong>
        <small>@summary.EligibleCount of @invoices.Count invoices</small>
    </article>
    <article class="metric-card">
        <span>Cash available today</span>
        <strong>@Money(summary.CashToday)</strong>
        <small>@terms.AdvanceRate.ToString("0")% advance</small>
    </article>
    <article class="metric-card">
        <span>Estimated total cost</span>
        <strong>@Money(summary.TotalCost)</strong>
        <small>@summary.EffectiveApr.ToString("0.0")% effective APR</small>
    </article>
    <article class="metric-card">
        <span>Portfolio quality</span>
        <strong>@summary.PortfolioQuality</strong>
        <small>@QualityLabel(summary.PortfolioQuality)</small>
    </article>
    <article class="metric-card">
        <span>Document readiness</span>
        <strong>@summary.DocumentReadyCount/@invoices.Count</strong>
        <small>@summary.MissingRequiredDocuments missing required docs</small>
    </article>
</section>

<section class="panel client-portal-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Client portal</p>
            <h2>Offer acceptance desk</h2>
            @if (!string.IsNullOrWhiteSpace(clientOfferMessage))
            {
                <small class="inline-status">@clientOfferMessage</small>
            }
        </div>
        <div class="heading-actions">
            <select class="memo-select" @bind="selectedOfferClientName">
                @foreach (var client in Portfolio.Clients)
                {
                    <option value="@client.Name">@client.Name</option>
                }
            </select>
            <button class="primary-action" disabled="@(!UserContext.CanUnderwrite)" @onclick="CreateClientOffer">Create offer</button>
        </div>
    </div>
    <div class="offer-grid">
        @foreach (var offer in Portfolio.ClientOffers.OrderByDescending(item => item.CreatedAt).Take(6))
        {
            <article class="offer-card">
                <div class="integration-head">
                    <span class="@ClientOfferStatusClass(offer.Status)">@offer.Status</span>
                    <span>@offer.OfferNumber</span>
                </div>
                <strong>@offer.ClientName</strong>
                <div class="offer-metrics">
                    <span>Gross <b>@Money(offer.GrossReceivables)</b></span>
                    <span>Net cash <b>@Money(offer.NetCash)</b></span>
                    <span>Fees <b>@Money(offer.Fees)</b></span>
                    <span>APR <b>@offer.EffectiveApr.ToString("0.0")%</b></span>
                </div>
                <p>@offer.InvoiceCount invoice(s): @offer.InvoiceNumbers</p>
                <div class="portal-link">
                    <span>/portal/@offer.PortalToken</span>
                    <small>Expires @offer.ExpiresAt.ToString("dd MMM") / @offer.SentToEmail</small>
                </div>
                <div class="collection-actions">
                    <button class="secondary-action" disabled="@(!UserContext.CanUnderwrite || offer.Status != ClientOfferStatus.Draft)" @onclick="() => SendClientOffer(offer)">Send</button>
                    <button class="secondary-action" disabled="@(!offer.IsActionable)" @onclick="() => AcceptClientOffer(offer)">Accept</button>
                    <button class="danger-action" disabled="@(!offer.IsActionable)" @onclick="() => DeclineClientOffer(offer)">Decline</button>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel action-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Action center</p>
            <h2>Priority work queue</h2>
        </div>
        <span class="status-pill">@myActionItems.Length assigned to @UserContext.CurrentUser.Role</span>
    </div>
    <div class="action-grid">
        @foreach (var item in actionItems)
        {
            var canComplete = UserContext.CurrentUser.Role == UserRole.Admin || item.OwnerRole == UserContext.CurrentUser.Role;
            <article class="action-card">
                <div class="action-card-head">
                    <span class="@ActionPriorityClass(item.Priority)">@item.Priority</span>
                    <span class="@RoleBadgeClass(item.OwnerRole)">@item.OwnerRole</span>
                </div>
                <strong>@item.Title</strong>
                <p>@item.Detail</p>
                <div class="action-meta">
                    <span>@item.Category</span>
                    <span>@item.RelatedEntity</span>
                    <span>Due @item.DueAt.ToString("MMM d")</span>
                </div>
                <button class="secondary-action" disabled="@(!canComplete)" @onclick="() => CompleteAction(item)">Complete</button>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Debtor verification</p>
            <h2>Confirmation workflow</h2>
        </div>
        <span class="status-pill">@Portfolio.DebtorConfirmations.Count(item => item.Status == DebtorConfirmationStatus.Sent) pending</span>
    </div>
    <div class="confirmation-grid">
        @foreach (var request in Portfolio.DebtorConfirmations.OrderByDescending(item => item.CreatedAt).Take(6))
        {
            <article class="confirmation-card">
                <div class="integration-head">
                    <span class="@ConfirmationStatusClass(request.Status)">@request.Status</span>
                    <span>@request.RequestNumber</span>
                </div>
                <strong>@request.InvoiceNumber / @request.Debtor</strong>
                <p>@request.ResponseNote</p>
                <div class="action-meta">
                    <span>Due @request.DueAt.ToString("MMM d")</span>
                    <span>@request.SentBy</span>
                </div>
                <div class="collection-actions">
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => ConfirmDebtorRequest(request)">Confirmed</button>
                    <button class="danger-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => DisputeDebtorRequest(request)">Disputed</button>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Dilution</p>
            <h2>Dispute cases</h2>
        </div>
        <span class="status-pill">@Portfolio.DisputeCases.Count(item => item.Status is not DisputeStatus.Resolved and not DisputeStatus.ChargedBack) open</span>
    </div>
    <div class="dispute-grid">
        @foreach (var dispute in Portfolio.DisputeCases.OrderByDescending(item => item.OpenedAt).Take(6))
        {
            <article class="dispute-card">
                <div class="integration-head">
                    <span class="@DisputeStatusClass(dispute.Status)">@dispute.Status</span>
                    <span>@dispute.CaseNumber</span>
                </div>
                <strong>@dispute.InvoiceNumber / @Money(dispute.DisputedAmount)</strong>
                <p>@dispute.Reason</p>
                <div class="action-meta">
                    <span>Credit @Money(dispute.CreditNoteAmount)</span>
                    <span>@dispute.Owner</span>
                </div>
                <div class="collection-actions">
                    <button class="secondary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => ResolveDispute(dispute, false)">Resolve</button>
                    <button class="danger-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="() => ResolveDispute(dispute, true)">Chargeback</button>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Payments</p>
            <h2>Reconciliation matches</h2>
        </div>
        <span class="status-pill">@Portfolio.PaymentMatches.Count matches</span>
    </div>
    <div class="payment-match-grid">
        @foreach (var match in Portfolio.PaymentMatches.OrderByDescending(item => item.ReceivedAt).Take(6))
        {
            <article class="payment-match-card">
                <div class="integration-head">
                    <span class="@PaymentMatchClass(match.Status)">@match.Status</span>
                    <span>@match.Reference</span>
                </div>
                <strong>@Money(match.Amount)</strong>
                <p>@match.InvoiceNumber / @match.Debtor</p>
                <small>@match.Note</small>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Funding operations</p>
            <h2>Funding batches</h2>
            @if (!string.IsNullOrWhiteSpace(fundingBatchMessage))
            {
                <small class="inline-status">@fundingBatchMessage</small>
            }
        </div>
        <button class="primary-action" disabled="@(!UserContext.CanOperateCollections)" @onclick="CreateFundingBatch">Fund approved</button>
    </div>
    <div class="batch-grid">
        @foreach (var batch in Portfolio.FundingBatches.OrderByDescending(item => item.CreatedAt).Take(4))
        {
            <article class="batch-card">
                <span>@batch.BatchNumber</span>
                <strong>@Money(batch.NetCash)</strong>
                <p>@batch.InvoiceCount invoice(s) / gross @Money(batch.GrossReceivables) / reserve @Money(batch.ReserveHeld)</p>
                <small>@batch.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm") / @batch.CreatedBy</small>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Funding ledger</p>
            <h2>Cash and reserve movements</h2>
        </div>
        <span class="status-pill">@ledgerEntries.Count entries</span>
    </div>
    <div class="ledger-metrics">
        <article>
            <span>Advances</span>
            <strong>@Money(ledgerSummary.Advances)</strong>
        </article>
        <article>
            <span>Fees</span>
            <strong>@Money(ledgerSummary.Fees)</strong>
        </article>
        <article>
            <span>Reserve held</span>
            <strong>@Money(ledgerSummary.ReserveHeld)</strong>
        </article>
        <article>
            <span>Payments</span>
            <strong>@Money(ledgerSummary.PaymentsReceived)</strong>
        </article>
        <article>
            <span>Net outstanding</span>
            <strong>@Money(ledgerSummary.NetOutstanding)</strong>
        </article>
    </div>
    <div class="ledger-list">
        @foreach (var entry in ledgerEntries.Take(8))
        {
            <div class="ledger-row">
                <span>@entry.EntryType</span>
                <strong>@entry.InvoiceNumber</strong>
                <p>@entry.ClientName / @entry.Debtor / @entry.Note</p>
                <b>@Money(entry.Debit - entry.Credit)</b>
            </div>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Monitoring</p>
            <h2>Portfolio covenants</h2>
        </div>
        <span class="status-pill">@covenantChecks.Count(item => item.Status != CovenantStatus.Pass) exceptions</span>
    </div>
    <div class="covenant-grid">
        @foreach (var check in covenantChecks.Take(8))
        {
            <article class="covenant-card">
                <div class="integration-head">
                    <span class="@CovenantStatusClass(check.Status)">@check.Status</span>
                    <span>@check.Scope</span>
                </div>
                <strong>@check.Name</strong>
                <p>@check.Action</p>
                <div class="action-meta">
                    <span>@check.Metric</span>
                    <span>@check.Threshold</span>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Borrowing base</p>
            <h2>Availability by client</h2>
        </div>
        <span class="status-pill">@Money(borrowingBaseSummary.Availability) available</span>
    </div>
    <div class="availability-strip">
        <article>
            <span>Gross AR</span>
            <strong>@Money(borrowingBaseSummary.GrossReceivables)</strong>
        </article>
        <article>
            <span>Eligible AR</span>
            <strong>@Money(borrowingBaseSummary.EligibleReceivables)</strong>
        </article>
        <article>
            <span>Borrowing base</span>
            <strong>@Money(borrowingBaseSummary.BorrowingBase)</strong>
        </article>
        <article>
            <span>Max advance</span>
            <strong>@Money(borrowingBaseSummary.MaxAdvance)</strong>
        </article>
        <article>
            <span>Existing advance</span>
            <strong>@Money(borrowingBaseSummary.ExistingAdvance)</strong>
        </article>
    </div>
    <div class="availability-table">
        @foreach (var line in borrowingBaseLines)
        {
            <div class="availability-row">
                <strong>@line.ClientName</strong>
                <span>@line.Status</span>
                <span>Eligible @Money(line.EligibleReceivables)</span>
                <span>Excess @Money(line.ConcentrationExcess + line.DebtorLimitExcess)</span>
                <b>@Money(line.Availability)</b>
            </div>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Fraud controls</p>
            <h2>Anomaly signals</h2>
        </div>
        <span class="status-pill">@fraudSignals.Count(item => item.Severity >= FraudSignalSeverity.High) high risk</span>
    </div>
    <div class="fraud-grid">
        @foreach (var signal in fraudSignals.Take(8))
        {
            <article class="fraud-card">
                <div class="integration-head">
                    <span class="@FraudSeverityClass(signal.Severity)">@signal.Severity</span>
                    <span>@signal.Entity</span>
                </div>
                <strong>@signal.SignalType</strong>
                <p>@signal.Detail</p>
                <small>@signal.RecommendedAction</small>
            </article>
        }
    </div>
</section>

<section class="content-grid">
    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Pricing</p>
                <h2>Deal terms</h2>
            </div>
        </div>
        <div class="form-grid">
            <label>Currency <input @bind="terms.Currency" /></label>
            <label>Advance rate <input type="number" @bind="terms.AdvanceRate" /></label>
            <label>Discount fee / 30d <input type="number" step="0.05" @bind="terms.DiscountRatePer30Days" /></label>
            <label>Service fee <input type="number" step="0.05" @bind="terms.ServiceFeeRate" /></label>
            <label>Minimum fee <input type="number" @bind="terms.MinimumFee" /></label>
            <label>Bank APR compare <input type="number" step="0.1" @bind="terms.BankApr" /></label>
        </div>
        <label class="toggle-line">
            <input type="checkbox" @bind="terms.IsNonRecourse" />
            Non-recourse pricing
        </label>
        <div class="policy-divider"></div>
        <div class="form-grid">
            <label>Minimum score <input type="number" @bind="terms.RiskPolicy.MinimumScore" /></label>
            <label>Max tenor days <input type="number" @bind="terms.RiskPolicy.MaximumTenorDays" /></label>
            <label>Long tenor review <input type="number" @bind="terms.RiskPolicy.LongTenorReviewDays" /></label>
            <label>Concentration warning <input type="number" step="0.5" @bind="terms.RiskPolicy.ConcentrationWarningPercent" /></label>
            <label>Facility warning % <input type="number" step="1" @bind="terms.RiskPolicy.FacilityWarningUtilizationPercent" /></label>
            <label>Credit warning % <input type="number" step="1" @bind="terms.RiskPolicy.CreditWarningUtilizationPercent" /></label>
            <label>High dilution % <input type="number" step="0.5" @bind="terms.RiskPolicy.HighDilutionPercent" /></label>
            <label>Slow payment days <input type="number" @bind="terms.RiskPolicy.SlowPaymentDays" /></label>
        </div>
    </article>

    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Workflow</p>
                <h2>Funding pipeline</h2>
            </div>
            <span class="status-pill">@ActiveCount() active</span>
        </div>
        <div class="workflow-grid">
            @foreach (var stage in Enum.GetValues<FundingStage>())
            {
                var stageInvoices = invoices.Where(invoice => invoice.FundingStage == stage).ToArray();
                <div class="workflow-card">
                    <span>@StageLabel(stage)</span>
                    <strong>@stageInvoices.Length</strong>
                    <small>@Money(stageInvoices.Sum(invoice => invoice.Amount))</small>
                </div>
            }
        </div>
    </article>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Documents</p>
            <h2>Template center</h2>
        </div>
        <select class="memo-select" @bind="selectedTemplateInvoiceNumber">
            @foreach (var invoice in invoices)
            {
                <option value="@invoice.InvoiceNumber">@invoice.InvoiceNumber / @invoice.Debtor</option>
            }
        </select>
    </div>
    <div class="template-grid">
        @foreach (var templateKind in Enum.GetValues<TemplateKind>())
        {
            <article class="template-card">
                <span>@TemplateLabel(templateKind)</span>
                <strong>@TemplateAudience(templateKind)</strong>
                <p>@TemplateDescription(templateKind)</p>
                <button class="secondary-action" @onclick="() => DownloadTemplate(templateKind)">Download TXT</button>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Microsoft integrations</p>
            <h2>Integration outbox</h2>
        </div>
        <span class="status-pill">@IntegrationOutbox.Events.Count(item => item.Status == IntegrationEventStatus.Pending) pending</span>
    </div>
    <div class="integration-grid">
        @foreach (var item in IntegrationOutbox.Events.Take(6))
        {
            <article class="integration-card">
                <div class="integration-head">
                    <span class="@IntegrationStatusClass(item.Status)">@item.Status</span>
                    <span>@item.Target</span>
                </div>
                <strong>@item.EventType</strong>
                <p>@item.Summary</p>
                <div class="action-meta">
                    <span>@item.Entity</span>
                    <span>@item.OccurredAt.ToLocalTime().ToString("MMM d HH:mm")</span>
                    <span>@item.Attempts attempts</span>
                </div>
                <div class="collection-actions">
                    <button class="secondary-action" @onclick="() => IntegrationOutbox.Retry(item.Id)">Retry</button>
                    <button class="secondary-action" @onclick="() => IntegrationOutbox.MarkDelivered(item.Id)">Mark delivered</button>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Reports</p>
            <h2>Export center</h2>
        </div>
        <span class="status-pill">CSV ready</span>
    </div>
    <div class="report-grid">
        @foreach (var report in Enum.GetValues<ReportKind>())
        {
            <article class="report-card">
                <span>@ReportLabel(report)</span>
                <strong>@ReportMetric(report)</strong>
                <p>@ReportDescription(report)</p>
                <button class="secondary-action" @onclick="() => ExportReport(report)">Download CSV</button>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Invoice book</p>
            <h2>Receivables</h2>
            @if (!string.IsNullOrWhiteSpace(importStatusMessage))
            {
                <small class="inline-status">@importStatusMessage</small>
            }
        </div>
        <div class="heading-actions">
            <label class="file-action">
                Import CSV
                <InputFile OnChange="ImportInvoiceCsv" />
            </label>
            <button class="secondary-action" @onclick="AddInvoice">Add invoice</button>
        </div>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Debtor</th>
                    <th>Client</th>
                    <th>Invoice no.</th>
                    <th>Amount</th>
                    <th>Days</th>
                    <th>Rating</th>
                    <th>Concentration</th>
                    <th>Status</th>
                    <th>Workflow</th>
                    <th>Score</th>
                    <th>Docs</th>
                    <th>Eligibility</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var invoice in invoices)
                {
                    var decision = Decide(invoice);
                    var docStatus = DocumentStatusLabel(invoice);
                    <tr>
                        <td><input @bind="invoice.Debtor" /></td>
                        <td>
                            <select @bind="invoice.ClientName">
                                @foreach (var client in Portfolio.Clients)
                                {
                                    <option value="@client.Name">@client.Name</option>
                                }
                            </select>
                        </td>
                        <td><input @bind="invoice.InvoiceNumber" /></td>
                        <td><input type="number" @bind="invoice.Amount" /></td>
                        <td><input type="number" @bind="invoice.DaysToPay" /></td>
                        <td>
                            <select @bind="invoice.Rating">
                                @foreach (var rating in Enum.GetValues<DebtorRating>())
                                {
                                    <option value="@rating">@rating</option>
                                }
                            </select>
                        </td>
                        <td><input type="number" @bind="invoice.ConcentrationPercent" /></td>
                        <td>
                            <select @bind="invoice.Status">
                                @foreach (var status in Enum.GetValues<InvoiceStatus>())
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </td>
                        <td>
                            <select @bind="invoice.FundingStage">
                                @foreach (var stage in Enum.GetValues<FundingStage>())
                                {
                                    <option value="@stage">@stage</option>
                                }
                            </select>
                        </td>
                        <td><span class="@ScoreClass(decision.Score)">@decision.Score</span></td>
                        <td><span class="@DocumentBadgeClass(invoice)">@docStatus</span></td>
                        <td>
                            <div class="reason-list">
                                @foreach (var reason in decision.Reasons)
                                {
                                    <span class="@ReasonClass(reason, decision)">@reason</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Documents</p>
            <h2>Funding checklist</h2>
        </div>
        <span class="status-pill">@summary.MissingRequiredDocuments missing</span>
    </div>
    <div class="document-grid">
        @foreach (var invoice in invoices)
        {
            <article class="document-card">
                <div class="document-card-head">
                    <div>
                        <strong>@invoice.InvoiceNumber</strong>
                        <span>@invoice.Debtor</span>
                    </div>
                    <span class="@DocumentBadgeClass(invoice)">@DocumentStatusLabel(invoice)</span>
                </div>
                <div class="document-list">
                    @foreach (var document in invoice.Documents)
                    {
                        <div class="document-row">
                            <label class="document-toggle">
                                <input type="checkbox" checked="@document.IsSatisfied" @onchange="eventArgs => ToggleDocument(document, eventArgs)" />
                                <span>@DocumentChecklistFactory.Label(document.Kind)</span>
                            </label>
                            <select @bind="document.Status">
                                @foreach (var status in Enum.GetValues<DocumentStatus>())
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                            <InputFile disabled="@(!CanUploadDocuments())" OnChange="eventArgs => UploadDocument(invoice, document, eventArgs)" />
                            <input placeholder="Reviewer note" @bind="document.ReviewerNote" />
                            <small class="document-meta">@DocumentMeta(document)</small>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</section>

<section class="profile-grid">
    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Clients</p>
                <h2>Facility exposure</h2>
            </div>
        </div>
        <div class="profile-list">
            @foreach (var client in Portfolio.Clients)
            {
                var exposure = Calculator.ClientExposure(invoices, client.Name);
                var utilization = client.FacilityLimit > 0 ? exposure / client.FacilityLimit * 100m : 0m;
                <div class="profile-card">
                    <div class="profile-head">
                        <div>
                            <strong>@client.Name</strong>
                            <span>@client.Industry / @client.Country</span>
                        </div>
                        <span class="@DecisionBadgeClass(client.BuyDecision)">@client.BuyDecision</span>
                    </div>
                    <div class="limit-row">
                        <span>Exposure</span>
                        <b>@Money(exposure)</b>
                    </div>
                    <div class="limit-track"><span style="width: @LimitWidth(utilization)"></span></div>
                    <div class="limit-meta">
                        <span>@utilization.ToString("0")% of @Money(client.FacilityLimit)</span>
                        <span>@client.KycStatus</span>
                    </div>
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Debtors</p>
                <h2>Credit limits</h2>
            </div>
        </div>
        <div class="profile-list">
            @foreach (var debtor in Portfolio.Debtors)
            {
                var exposure = Calculator.DebtorExposure(invoices, debtor.Name);
                var utilization = debtor.CreditLimit > 0 ? exposure / debtor.CreditLimit * 100m : 0m;
                <div class="profile-card">
                    <div class="profile-head">
                        <div>
                            <strong>@debtor.Name</strong>
                            <span>@debtor.Sector / @debtor.Country</span>
                        </div>
                        <span class="@DecisionBadgeClass(debtor.BuyDecision)">@debtor.BuyDecision</span>
                    </div>
                    <div class="limit-row">
                        <span>Exposure</span>
                        <b>@Money(exposure)</b>
                    </div>
                    <div class="limit-track"><span style="width: @LimitWidth(utilization)"></span></div>
                    <div class="limit-meta">
                        <span>@utilization.ToString("0")% of @Money(debtor.CreditLimit)</span>
                        <span>@debtor.Rating / @debtor.AverageDaysToPay days</span>
                    </div>
                </div>
            }
        </div>
    </article>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Underwriting</p>
            <h2>Approval desk</h2>
        </div>
        <span class="status-pill">@PendingUnderwritingCount() pending</span>
    </div>
    <div class="underwriting-list">
        @foreach (var invoice in invoices.Where(invoice => invoice.FundingStage != FundingStage.Settled))
        {
            var decision = Decide(invoice);
            var underwriting = Portfolio.DecisionFor(invoice.InvoiceNumber);
            <article class="underwriting-card">
                <div class="underwriting-head">
                    <div>
                        <strong>@invoice.InvoiceNumber</strong>
                        <span>@invoice.ClientName / @invoice.Debtor</span>
                    </div>
                    <span class="@UnderwritingBadgeClass(underwriting.Status)">@UnderwritingLabel(underwriting.Status)</span>
                </div>
                <div class="underwriting-facts">
                    <span>Score <b>@decision.Score</b></span>
                    <span>Docs <b>@DocumentStatusLabel(invoice)</b></span>
                    <span>Assigned <b>@underwriting.AssignedTo</b></span>
                    <span>Stage <b>@invoice.FundingStage</b></span>
                </div>
                <div class="underwriting-reasons">
                    @foreach (var reason in decision.Reasons)
                    {
                        <span class="@ReasonClass(reason, decision)">@reason</span>
                    }
                </div>
                <div class="underwriting-form">
                    <input placeholder="Decision note" @bind="underwriting.DecisionNote" />
                    <input placeholder="Conditions" @bind="underwriting.Conditions" />
                </div>
                <div class="underwriting-actions">
                    <button class="secondary-action" disabled="@(!UserContext.CanUnderwrite)" @onclick="() => SetDecision(invoice, UnderwritingDecisionStatus.Approved)">Approve</button>
                    <button class="secondary-action" disabled="@(!UserContext.CanUnderwrite)" @onclick="() => SetDecision(invoice, UnderwritingDecisionStatus.ApprovedWithConditions)">Condition</button>
                    <button class="danger-action" disabled="@(!UserContext.CanUnderwrite)" @onclick="() => SetDecision(invoice, UnderwritingDecisionStatus.Declined)">Decline</button>
                    <button class="warning-action" disabled="@(!UserContext.CanUnderwrite)" @onclick="() => SetDecision(invoice, UnderwritingDecisionStatus.OverrideApproved)">Override</button>
                </div>
            </article>
        }
    </div>
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Audit</p>
            <h2>Decision trail</h2>
        </div>
    </div>
    <div class="audit-list">
        @foreach (var auditEvent in Portfolio.AuditEvents.OrderByDescending(item => item.OccurredAt).Take(8))
        {
            <div class="audit-row">
                <span>@auditEvent.OccurredAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                <strong>@auditEvent.Action</strong>
