<section class="insight-grid">
    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Risk</p>
                <h2>Underwriting signals</h2>
            </div>
        </div>
        <ul class="signal-list">
            @foreach (var signal in Signals())
            {
                <li>@signal</li>
            }
        </ul>
    </article>

    <article class="panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow">Offer</p>
                <h2>Indicative term sheet</h2>
            </div>
        </div>
        <pre>@TermSheet(summary)</pre>
    </article>
</section>

@code {
    private string? selectedMemoInvoiceNumber;
    private string? selectedTemplateInvoiceNumber;
    private string importStatusMessage = "";
    private string fundingBatchMessage = "";
    private string paymentReconciliationMessage = "";
    private string clientOfferMessage = "";
    private string? selectedOfferClientName;
    private readonly HashSet<string> CompletedActionIds = new(StringComparer.OrdinalIgnoreCase);

    private string Money(decimal value) => $"{Portfolio.Terms.Currency} {value:N0}";

    private void SwitchUser(ChangeEventArgs eventArgs)
    {
        UserContext.SwitchTo(Convert.ToString(eventArgs.Value) ?? "");
    }

    private Invoice? SelectedMemoInvoice()
    {
        selectedMemoInvoiceNumber ??= Portfolio.Invoices.FirstOrDefault()?.InvoiceNumber;
        return Portfolio.Invoices.FirstOrDefault(invoice => invoice.InvoiceNumber == selectedMemoInvoiceNumber);
    }

    private Invoice? SelectedTemplateInvoice()
    {
        selectedTemplateInvoiceNumber ??= Portfolio.Invoices.FirstOrDefault()?.InvoiceNumber;
        return Portfolio.Invoices.FirstOrDefault(invoice => invoice.InvoiceNumber == selectedTemplateInvoiceNumber);
    }

    private DocumentExtractionResult ExtractFirstDocument(Invoice invoice)
    {
        var document = invoice.Documents.FirstOrDefault(item => !string.IsNullOrWhiteSpace(item.FileName))
            ?? invoice.Documents.FirstOrDefault();
        return document is null
            ? new DocumentExtractionResult { IsAvailable = false, Summary = "No checklist item available." }
            : DocumentExtraction.Extract(document);
    }

    private bool CanUploadDocuments() =>
        UserContext.CurrentUser.Role is UserRole.Client or UserRole.Underwriter or UserRole.Admin;

    private static string QualityLabel(int score) =>
        score >= 75 ? "Strong" : score >= 55 ? "Watchlist" : score > 0 ? "High risk" : "No data";

    private static string StageLabel(FundingStage stage) => stage switch
    {
        FundingStage.Review => "Review",
        _ => stage.ToString()
    };

    private int ActiveCount() =>
        Portfolio.Invoices.Count(invoice => invoice.FundingStage != FundingStage.Draft && invoice.FundingStage != FundingStage.Settled);

    private void SubmitEligible()
    {
        var submitted = 0;
        foreach (var invoice in Portfolio.Invoices)
        {
            if (!UserContext.CanSubmitFunding) return;

            if (invoice.FundingStage == FundingStage.Draft && Decide(invoice).IsEligible)
            {
                invoice.FundingStage = FundingStage.Submitted;
                submitted++;
            }
        }

        if (submitted > 0)
        {
            IntegrationOutbox.Publish("Funding.Submitted", "Portfolio", $"{submitted} eligible invoice(s) submitted for underwriting.", "Power Automate");
            foreach (var line in BorrowingBase.Build(Portfolio, Portfolio.Terms).Where(line => line.Availability <= 0m))
            {
                IntegrationOutbox.Publish("BorrowingBase.NoAvailability", line.ClientName, $"{line.ClientName} has {Money(line.Availability)} available after current base and advances.", "Microsoft Teams");
            }
        }
    }

    private void CreateClientOffer()
    {
        if (!UserContext.CanUnderwrite) return;

        selectedOfferClientName ??= Portfolio.Clients.FirstOrDefault()?.Name;
        if (string.IsNullOrWhiteSpace(selectedOfferClientName)) return;

        var offer = ClientOffers.CreateOffer(Portfolio, selectedOfferClientName, UserContext.CurrentUser.DisplayName);
        if (offer is null)
        {
            clientOfferMessage = "No eligible submitted, review or approved invoices for selected client.";
            return;
        }

        clientOfferMessage = $"{offer.OfferNumber}: {offer.InvoiceCount} invoice(s), net cash {Money(offer.NetCash)}.";
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = offer.OfferNumber,
            Action = "Offer created",
            Detail = $"{offer.ClientName} / {Money(offer.NetCash)} net cash"
        });
        IntegrationOutbox.Publish("ClientOffer.Created", offer.OfferNumber, $"{offer.ClientName} offer created for {offer.InvoiceCount} invoice(s).", "Dynamics 365");
    }

    private void SendClientOffer(ClientOffer offer)
    {
        if (!UserContext.CanUnderwrite) return;

        ClientOffers.Send(offer);
        clientOfferMessage = $"{offer.OfferNumber} sent to {offer.SentToEmail}.";
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = offer.OfferNumber,
            Action = "Offer sent",
            Detail = $"Portal token {offer.PortalToken}"
        });
        IntegrationOutbox.Publish("ClientOffer.Sent", offer.OfferNumber, $"Offer sent to {offer.SentToEmail}.", "Outlook");
    }

    private void AcceptClientOffer(ClientOffer offer)
    {
        ClientOffers.Accept(Portfolio, offer, UserContext.CurrentUser.DisplayName);
        clientOfferMessage = $"{offer.OfferNumber} accepted.";
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = offer.OfferNumber,
            Action = "Offer accepted",
            Detail = $"{offer.ClientName} accepted {Money(offer.NetCash)} net cash."
        });
        IntegrationOutbox.Publish("ClientOffer.Accepted", offer.OfferNumber, $"{offer.ClientName} accepted offer in portal.", "Dynamics 365");
    }

    private void DeclineClientOffer(ClientOffer offer)
    {
        ClientOffers.Decline(offer, UserContext.CurrentUser.DisplayName);
        clientOfferMessage = $"{offer.OfferNumber} declined.";
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = offer.OfferNumber,
            Action = "Offer declined",
            Detail = offer.Notes
        });
        IntegrationOutbox.Publish("ClientOffer.Declined", offer.OfferNumber, $"{offer.ClientName} declined offer.", "Dynamics 365");
    }

    private void CompleteAction(ActionItem item)
    {
        if (UserContext.CurrentUser.Role != UserRole.Admin && UserContext.CurrentUser.Role != item.OwnerRole) return;

        CompletedActionIds.Add(item.Id);
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = item.RelatedEntity,
            Action = "Action completed",
            Detail = $"{item.Title}: {item.Detail}"
        });
        IntegrationOutbox.Publish("Action.Completed", item.RelatedEntity, item.Title, "Microsoft Teams");
    }

    private async Task ImportInvoiceCsv(InputFileChangeEventArgs eventArgs)
    {
        var file = eventArgs.File;
        using var stream = file.OpenReadStream(1024 * 1024);
        using var reader = new StreamReader(stream);
        var csv = await reader.ReadToEndAsync();
        var result = InvoiceImport.Import(csv, Portfolio);
        importStatusMessage = result.HasErrors
            ? $"Imported {result.Added} added / {result.Updated} updated with {result.Errors.Count} issue(s)."
            : $"Imported {result.Added} added / {result.Updated} updated.";

        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = file.Name,
            Action = "CSV imported",
            Detail = importStatusMessage
        });
        IntegrationOutbox.Publish("InvoiceBook.Imported", "Portfolio", importStatusMessage, "Power Automate");
    }

    private void CreateFundingBatch()
    {
        if (!UserContext.CanOperateCollections) return;

        var batch = FundingBatchService.CreateApprovedBatch(Portfolio, Portfolio.Terms, UserContext.CurrentUser.DisplayName);
        if (batch is null)
        {
            fundingBatchMessage = "No approved invoices available for funding.";
            return;
        }

        fundingBatchMessage = $"{batch.BatchNumber}: {batch.InvoiceCount} invoice(s), net cash {Money(batch.NetCash)}.";
        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = batch.BatchNumber,
            Action = "Funding batch created",
            Detail = $"{batch.InvoiceCount} invoice(s) funded: {batch.InvoiceNumbers}"
        });
        IntegrationOutbox.Publish("FundingBatch.Created", batch.BatchNumber, fundingBatchMessage, "Power Automate");
    }

    private async Task ReconcilePaymentCsv(InputFileChangeEventArgs eventArgs)
    {
        if (!UserContext.CanOperateCollections) return;

        var file = eventArgs.File;
        using var stream = file.OpenReadStream(1024 * 1024);
        using var reader = new StreamReader(stream);
        var csv = await reader.ReadToEndAsync();
        var result = PaymentReconciliation.Reconcile(csv, Portfolio);
        paymentReconciliationMessage = result.HasErrors
            ? $"{result.Matched} matched / {result.Partial} partial / {result.Unmatched} unmatched with {result.Errors.Count} issue(s)."
            : $"{result.Matched} matched / {result.Partial} partial / {result.Unmatched} unmatched.";

        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = file.Name,
            Action = "Payments reconciled",
            Detail = paymentReconciliationMessage
        });
        IntegrationOutbox.Publish("Payments.Reconciled", "Portfolio", paymentReconciliationMessage, "Power Automate");
    }

    private void AddInvoice()
    {
        var invoice = new Invoice
        {
            ClientName = Portfolio.Clients.FirstOrDefault()?.Name ?? "",
            Debtor = "New debtor",
            InvoiceNumber = $"INV-{DateTime.UtcNow.Year}-{Portfolio.Invoices.Count + 1:0000}",
            Amount = 10000m,
            DaysToPay = 45,
            Rating = DebtorRating.B,
            ConcentrationPercent = 20m,
            Status = InvoiceStatus.Clean,
            FundingStage = FundingStage.Draft
        };
        invoice.Documents.AddRange(DocumentChecklistFactory.CreateDefault());
        foreach (var document in invoice.Documents)
        {
            document.InvoiceNumber = invoice.InvoiceNumber;
        }
        Portfolio.Invoices.Add(invoice);
        Portfolio.DecisionFor(invoice.InvoiceNumber);
        Portfolio.CollectionCaseFor(invoice.InvoiceNumber);
        Portfolio.AuditEvents.Add(new AuditEvent { Actor = "System", Entity = invoice.InvoiceNumber, Action = "Created", Detail = "Draft invoice added to underwriting queue." });
        IntegrationOutbox.Publish("Invoice.Created", invoice.InvoiceNumber, $"{invoice.ClientName} added {Money(invoice.Amount)} receivable.", "Power Automate");
    }

    private int PendingUnderwritingCount() =>
        Portfolio.UnderwritingDecisions.Count(decision => decision.Status == UnderwritingDecisionStatus.Pending);

    private void SetDecision(Invoice invoice, UnderwritingDecisionStatus status)
    {
        if (!UserContext.CanUnderwrite) return;

        var decision = Portfolio.DecisionFor(invoice.InvoiceNumber);
        decision.Status = status;
        decision.DecidedAt = DateTime.UtcNow;
        decision.IsManualOverride = status == UnderwritingDecisionStatus.OverrideApproved;
        decision.AssignedTo = UserContext.CurrentUser.DisplayName;

        invoice.FundingStage = status switch
        {
            UnderwritingDecisionStatus.Approved => FundingStage.Approved,
            UnderwritingDecisionStatus.OverrideApproved => FundingStage.Approved,
            UnderwritingDecisionStatus.ApprovedWithConditions => FundingStage.Review,
            UnderwritingDecisionStatus.Declined => FundingStage.Draft,
            _ => invoice.FundingStage
        };

        var action = status switch
        {
            UnderwritingDecisionStatus.Approved => "Approved",
            UnderwritingDecisionStatus.ApprovedWithConditions => "Conditioned",
            UnderwritingDecisionStatus.Declined => "Declined",
            UnderwritingDecisionStatus.OverrideApproved => "Override approved",
            _ => "Updated"
        };

        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = decision.AssignedTo,
            Entity = invoice.InvoiceNumber,
            Action = action,
            Detail = string.IsNullOrWhiteSpace(decision.DecisionNote) ? "Decision updated from underwriting desk." : decision.DecisionNote
        });
        IntegrationOutbox.Publish("Underwriting.Decision", invoice.InvoiceNumber, $"{action}: {invoice.Debtor} / {Money(invoice.Amount)}.", "Microsoft Teams");
    }

    private int OverdueCount() =>
        Portfolio.CollectionCases.Count(item => item.Status is CollectionStatus.Overdue or CollectionStatus.Chargeback || item.DaysPastDue > 0 && item.Status != CollectionStatus.Paid);

    private IEnumerable<(string Label, int Count, decimal Amount)> AgingBuckets()
    {
        var joined = Portfolio.CollectionCases
            .Select(item => new { Case = item, Invoice = Portfolio.Invoices.FirstOrDefault(invoice => invoice.InvoiceNumber == item.InvoiceNumber) })
            .Where(item => item.Invoice is not null)
            .ToArray();

        yield return ("Not due", joined.Count(item => item.Case.DaysPastDue == 0 && item.Case.Status != CollectionStatus.Paid), joined.Where(item => item.Case.DaysPastDue == 0 && item.Case.Status != CollectionStatus.Paid).Sum(item => item.Invoice!.Amount));
        yield return ("1-15 DPD", joined.Count(item => item.Case.DaysPastDue is >= 1 and <= 15), joined.Where(item => item.Case.DaysPastDue is >= 1 and <= 15).Sum(item => item.Invoice!.Amount));
        yield return ("16-45 DPD", joined.Count(item => item.Case.DaysPastDue is >= 16 and <= 45), joined.Where(item => item.Case.DaysPastDue is >= 16 and <= 45).Sum(item => item.Invoice!.Amount));
        yield return ("45+ DPD", joined.Count(item => item.Case.DaysPastDue > 45), joined.Where(item => item.Case.DaysPastDue > 45).Sum(item => item.Invoice!.Amount));
        yield return ("Paid", joined.Count(item => item.Case.Status == CollectionStatus.Paid), joined.Where(item => item.Case.Status == CollectionStatus.Paid).Sum(item => item.Invoice!.Amount));
    }

