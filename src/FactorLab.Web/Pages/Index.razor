    private static string DocumentStatusLabel(Invoice invoice)
    {
        if (invoice.Documents.Count == 0) return "No checklist";

        var required = invoice.Documents.Where(document => document.IsRequired).ToArray();
        var missing = required.Count(document => !document.IsSatisfied);
        if (missing == 0) return "Ready";

        var uploaded = required.Count(document => document.Status == DocumentStatus.Uploaded);
        return uploaded > 0 ? $"{missing} pending" : $"{missing} missing";
    }

    private static string DocumentBadgeClass(Invoice invoice)
    {
        if (invoice.Documents.Count == 0) return "doc-badge missing";

        var required = invoice.Documents.Where(document => document.IsRequired).ToArray();
        if (required.All(document => document.IsSatisfied)) return "doc-badge ready";
        if (required.Any(document => document.Status == DocumentStatus.Uploaded)) return "doc-badge pending";
        return "doc-badge missing";
    }

    private static void ToggleDocument(DocumentRequirement document, ChangeEventArgs eventArgs)
    {
        var isChecked = eventArgs.Value is bool value && value;
        document.Status = isChecked ? DocumentStatus.Verified : DocumentStatus.Missing;
        document.ReceivedAt = isChecked ? DateTime.UtcNow : null;
        document.FileName = isChecked && string.IsNullOrWhiteSpace(document.FileName)
            ? $"{DocumentChecklistFactory.Label(document.Kind).Replace(" ", "-").ToLowerInvariant()}.pdf"
            : document.FileName;
    }

    private async Task UploadDocument(Invoice invoice, DocumentRequirement document, InputFileChangeEventArgs eventArgs)
    {
        if (!CanUploadDocuments()) return;

        var file = eventArgs.File;
        var stored = await DocumentStorage.SaveAsync(invoice.InvoiceNumber, document.Kind, file);
        document.InvoiceNumber = invoice.InvoiceNumber;
        document.FileName = stored.FileName;
        document.StoredPath = stored.StoredPath;
        document.ContentType = stored.ContentType;
        document.SizeBytes = stored.SizeBytes;
        document.UploadedBy = UserContext.CurrentUser.DisplayName;
        document.ReceivedAt = DateTime.UtcNow;
        document.Status = DocumentStatus.Uploaded;
        document.ReviewerNote = string.IsNullOrWhiteSpace(document.ReviewerNote)
            ? "Uploaded and awaiting verification."
            : document.ReviewerNote;

        Portfolio.AuditEvents.Add(new AuditEvent
        {
            Actor = UserContext.CurrentUser.DisplayName,
            Entity = invoice.InvoiceNumber,
            Action = "Document uploaded",
            Detail = $"{DocumentChecklistFactory.Label(document.Kind)} uploaded: {stored.FileName}"
        });
        IntegrationOutbox.Publish("Document.Uploaded", invoice.InvoiceNumber, $"{DocumentChecklistFactory.Label(document.Kind)} uploaded for extraction.", "Azure AI Document Intelligence");
    }

    private static string DocumentMeta(DocumentRequirement document)
    {
        if (string.IsNullOrWhiteSpace(document.FileName)) return "No file uploaded";

        var size = document.SizeBytes > 0 ? $"{document.SizeBytes / 1024m:0.0} KB" : "sample file";
        var uploadedBy = string.IsNullOrWhiteSpace(document.UploadedBy) ? "sample data" : document.UploadedBy;
        return $"{document.FileName} / {size} / {uploadedBy}";
    }

    private static string ReasonClass(string reason, EligibilityDecision decision)
    {
        if (decision.Blockers.Contains(reason)) return "reason-chip blocker";
        if (decision.Warnings.Contains(reason)) return "reason-chip warning";
        return "reason-chip ready";
    }
