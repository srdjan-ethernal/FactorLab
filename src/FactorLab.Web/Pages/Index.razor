</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">AI-ready</p>
            <h2>Risk memo</h2>
        </div>
        <select class="memo-select" @bind="selectedMemoInvoiceNumber">
            @foreach (var invoice in invoices)
            {
                <option value="@invoice.InvoiceNumber">@invoice.InvoiceNumber / @invoice.Debtor</option>
            }
        </select>
    </div>
    @{
        var memoInvoice = SelectedMemoInvoice();
        if (memoInvoice is not null)
        {
            var memo = RiskMemoService.Generate(memoInvoice, Portfolio, terms);
            var extracted = ExtractFirstDocument(memoInvoice);
            <div class="memo-grid">
                <article class="memo-card">
                    <span>Recommendation</span>
                    <strong>@memo.Recommendation</strong>
                    <p>@memo.ExecutiveSummary</p>
                    <small>Generated @memo.GeneratedAt.ToLocalTime().ToString("dd MMM HH:mm")</small>
                </article>
                <article class="memo-card">
                    <span>Document intelligence</span>
                    <strong>@(extracted.IsAvailable ? "Metadata ready" : "Waiting for upload")</strong>
                    <p>@extracted.Summary</p>
                    @foreach (var field in extracted.Fields)
                    {
                        <small>@field.Key: @field.Value</small>
                    }
                </article>
            </div>
            <div class="memo-columns">
                <div>
                    <h3>Strengths</h3>
                    @foreach (var item in memo.Strengths)
                    {
                        <span class="memo-chip strength">@item</span>
                    }
                </div>
                <div>
                    <h3>Risks</h3>
                    @foreach (var item in memo.Risks)
                    {
                        <span class="memo-chip risk">@item</span>
                    }
                </div>
                <div>
                    <h3>Conditions</h3>
                    @foreach (var item in memo.Conditions)
                    {
                        <span class="memo-chip condition">@item</span>
                    }
                </div>
            </div>
        }
    }
</section>

<section class="panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Collections</p>
            <h2>Aging pipeline</h2>
            @if (!string.IsNullOrWhiteSpace(paymentReconciliationMessage))
            {
                <small class="inline-status">@paymentReconciliationMessage</small>
            }
        </div>
        <div class="heading-actions">
            <label class="file-action">
                Reconcile CSV
                <InputFile disabled="@(!UserContext.CanOperateCollections)" OnChange="ReconcilePaymentCsv" />
            </label>
            <span class="status-pill">@OverdueCount() overdue</span>
        </div>
    </div>
    <div class="aging-grid">
        @foreach (var bucket in AgingBuckets())
        {
            <article class="aging-card">
                <span>@bucket.Label</span>
                <strong>@bucket.Count</strong>
                <small>@Money(bucket.Amount)</small>
            </article>
        }
    </div>
    <div class="collections-list">
        @foreach (var invoice in invoices)
        {
            var collectionCase = Portfolio.CollectionCaseFor(invoice.InvoiceNumber);
            <article class="collection-card">
                <div class="collection-head">
                    <div>
                        <strong>@invoice.InvoiceNumber</strong>
                        <span>@invoice.Debtor / due @collectionCase.DueDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <span class="@CollectionBadgeClass(collectionCase.Status)">@CollectionLabel(collectionCase.Status)</span>
                </div>
                <div class="collection-facts">
                    <span>Amount <b>@Money(invoice.Amount)</b></span>
                    <span>Paid <b>@Money(collectionCase.AmountPaid)</b></span>
                    <span>Reserve <b>@Money(collectionCase.ReserveReleased)</b></span>
                    <span>DPD <b>@collectionCase.DaysPastDue</b></span>
